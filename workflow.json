    {
      "parameters": {
        "jsCode": "const output = $('AI Agent').item.json.output;\nconst date = new Date().toLocaleDateString('da-DK');\n\nconst blocks = output.split(/COMBO \\d+/i).filter(b => b.trim());\n\nconst get = (block, key) => {\n  const m = block.match(new RegExp(key + ':\\\\s*(.+)', 'i'));\n  return m ? m[1].trim() : '';\n};\n\nconst cleanPrice = (val) => {\n  const num = parseFloat(val.replace(/[^0-9.]/g, ''));\n  return isNaN(num) ? 0 : num;\n};\n\nconst cleanPercent = (val) => {\n  const num = parseFloat(val.replace(/[^0-9.]/g, ''));\n  return isNaN(num) ? 0 : num;\n};\n\nconst rows = blocks.map(block => {\n  const comboName = get(block, 'COMBO_NAME');\n  const products = get(block, 'PRODUCTS');\n  const daysLeft = get(block, 'DAYS_LEFT');\n  const urgency = get(block, 'URGENCY');\n  const discountStr = get(block, 'DISCOUNT');\n  const discountPct = cleanPercent(discountStr);\n  const discountDecimal = discountPct / 100;\n\n  // Get original price from Llama\n  let origPrice = cleanPrice(get(block, 'ORIGINAL_PRICE'));\n\n  // Calculate final price and savings ourselves — don't trust Llama's arithmetic\n  const correctedFinal = origPrice > 0 ? \n    parseFloat((origPrice * (1 - discountDecimal)).toFixed(2)) : \n    cleanPrice(get(block, 'FINAL_PRICE'));\n\n  const correctedSavings = origPrice > 0 ? \n    parseFloat((origPrice * discountDecimal).toFixed(2)) : \n    cleanPrice(get(block, 'SAVINGS'));\n\n  return {\n    Date: date,\n    'Combo Name': comboName,\n    Products: products,\n    'Days Left': daysLeft,\n    Urgency: urgency,\n    Discount: discountPct + '%',\n    'Original Price (DKK)': origPrice.toFixed(2),\n    'Final Price (DKK)': correctedFinal,\n    'Savings (DKK)': correctedSavings,\n    'Stock Available': get(block, 'STOCK'),\n    'Max Combos': get(block, 'MAX_COMBOS').replace(/[^0-9]/g, ''),\n    'Meal Occasion': get(block, 'MEAL_OCCASION'),\n    Action: get(block, 'ACTION')\n  };\n}).filter(r => r['Combo Name']);\n\nreturn rows.map(r => ({ json: r }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1168,
