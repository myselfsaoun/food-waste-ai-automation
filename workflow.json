    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a supermarket marketing assistant creating promotional materials.\n\nBased on these combo deals:\n{{ $json.output }}\n\nGenerate a promotional leaflet with TWO sections:\n\n--- SHELF LABELS ---\nFor each combo create a small shelf label with:\nCOMBO NAME: [name in capitals]\nPRODUCTS: [list products]\nDISCOUNT: [X]% OFF\nPRICE: [final price] DKK\nURGENCY: [e.g. \"Use by today!\" or \"Only 3 days left!\"]\nPROMO LINE: [one catchy line]\n\n--- A4 FLYER ---\nCreate one A4 promotional flyer featuring all 3 combos with:\nHEADLINE: [catchy store headline e.g. \"Today's Waste Saver Deals!\"]\nFor each combo include:\n- Combo name and products\n- Simple 3-step recipe or serving suggestion\n- Discount and final price\n- Why it's good value\nEnd with a sustainability message about reducing food waste.\n\nKeep the language simple, friendly and suitable for Danish supermarket customers.",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1376,
        16
      ],
      "id": "6b776690-72d3-4a1e-abf0-78460ec55742",
      "name": "AI Agent1"
    },
    {
      "parameters": {
        "model": "llama3:latest",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
