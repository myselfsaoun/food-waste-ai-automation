    {
      "parameters": {
        "jsCode": "const comboText = $('AI Agent').item.json.output\n  .replace(/\\n/g, ' ')\n  .replace(/\\r/g, '');\n\nconst prompt = `Professional supermarket promotional flyer, bold title WASTE SAVER DEALS, red and yellow colors, 3 food combo cards with appetizing food photos, discount badges, prices in DKK, style similar to Lidl supermarket. Combos: ${comboText.substring(0, 200)}`;\n\nconst response = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://router.huggingface.co/hf-inference/models/black-forest-labs/FLUX.1-schnell',\n  headers: {\n    'Authorization': 'Bearer YOUR_HUGGINGFACE_TOKEN',\n    'Content-Type': 'application/json',\n    'Accept': 'image/png'\n  },\n  body: JSON.stringify({\n    inputs: prompt,\n    parameters: { num_inference_steps: 5 }\n  }),\n  encoding: 'arraybuffer',\n  returnFullResponse: true\n});\n\nconst base64 = Buffer.from(response.body).toString('base64');\nconst fileName = `flyer_${new Date().toISOString().slice(0,10)}.png`;\n\nreturn [{\n  json: { fileName },\n  binary: {\n    data: {\n      data: base64,\n      mimeType: 'image/png',\n      fileName\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1712,
        16
      ],
      "id": "da755327-7a90-4d1d-9c4f-b8360b68953b",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "name": "={{ $json.fileName }}",
        "driveId": {
          "__rl": true,
          "mode": "list",
          "value": "My Drive"
